<style is:global>
  :root {
    --amber: #F0C060;
    --amber-dim: #C88A28;
    --frost: #EEF2FF;
    --muted: #7A8CAF;
    --border: rgba(30, 46, 71, 0.9);
    --card-bg: rgba(11, 20, 34, 0.75);
  }




  * { box-sizing: border-box; }




  html { font-family: 'DM Sans', sans-serif; }




  body {
    background: #040710;
    color: #EEF2FF;
    overflow-x: hidden;
  }




  /* ── Background grid ── */
  .bg-grid {
    background-image:
      linear-gradient(rgba(30,46,71,.35) 1px, transparent 1px),
      linear-gradient(90deg, rgba(30,46,71,.35) 1px, transparent 1px);
    background-size: 64px 64px;
  }




  /* ── Glass ── */
  .glass {
    background: var(--card-bg);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--border);
  }




  /* ── Orbital rings ── */
  @keyframes spin-cw  { to { transform: translate(-50%,-50%) rotate(360deg); } }
  @keyframes spin-ccw { to { transform: translate(-50%,-50%) rotate(-360deg); } }
  @keyframes spin-med { to { transform: translate(-50%,-50%) rotate(360deg); } }




  .ring { position: absolute; border-radius: 50%; top: 50%; left: 50%; transform-origin: center; }
  .ring-1 { animation: spin-cw  55s linear infinite; }
  .ring-2 { animation: spin-ccw 38s linear infinite; }
  .ring-3 { animation: spin-med 22s linear infinite; }




  /* Satellite dot travelling along ring-3 */
  @keyframes sat-travel {
    from { transform: rotate(0deg)   translateX(var(--r)) rotate(0deg); }
    to   { transform: rotate(360deg) translateX(var(--r)) rotate(-360deg); }
  }
  .sat-dot {
    --r: 210px;
    position: absolute; top: 50%; left: 50%;
    width: 7px; height: 7px; margin: -3.5px;
    border-radius: 50%;
    background: var(--amber);
    box-shadow: 0 0 10px 4px rgba(240,192,96,.55);
    animation: sat-travel 22s linear infinite;
  }
  @media (max-width: 768px) {
    .sat-dot { --r: 130px; }
  }




  /* ── Text gradient ── */
  .grad-amber {
    background: linear-gradient(130deg, #F5D070 0%, #E0A838 45%, #FFE8A0 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }




  /* ── Glow ── */
  .hero-glow { text-shadow: 0 0 60px rgba(240,192,96,.35); }
  .card-hover {
    transition: transform .3s ease, border-color .3s ease, box-shadow .3s ease;
    border: 1px solid var(--border);
  }
  .card-hover:hover {
    transform: translateY(-5px);
    border-color: rgba(240,192,96,.28);
    box-shadow: 0 22px 44px rgba(0,0,0,.35), 0 0 36px rgba(240,192,96,.06);
  }




  /* ── Team cards ── */
  .team-img { transition: transform .45s ease; }
  .team-card:hover .team-img { transform: scale(1.06); }
  .team-frame { transition: border-color .3s ease; }
  .team-card:hover .team-frame { border-color: rgba(240,192,96,.45); }




  /* ── Reveal on scroll ── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .65s ease, transform .65s ease;
  }
  .reveal.up {
    opacity: 1;
    transform: translateY(0);
  }




  /* ── Fade-in stagger for hero ── */
  @keyframes fadeUp {
    from { opacity:0; transform:translateY(28px); }
    to   { opacity:1; transform:translateY(0); }
  }
  .fi { animation: fadeUp .9s ease forwards; }
  .fi-1 { animation-delay:.10s; opacity:0; }
  .fi-2 { animation-delay:.28s; opacity:0; }
  .fi-3 { animation-delay:.46s; opacity:0; }
  .fi-4 { animation-delay:.64s; opacity:0; }
  .fi-5 { animation-delay:.82s; opacity:0; }
  .fi-6 { animation-delay:1.0s; opacity:0; }




  /* ── Nav ── */
  .nav-shell {
    background: rgba(4,7,16,.88);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
    border-bottom: 1px solid rgba(30,46,71,.55);
  }




  /* ── Scanlines (telemetry box) ── */
  .scanlines::after {
    content: '';
    position: absolute; inset: 0; pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      transparent, transparent 3px,
      rgba(0,0,0,.04) 3px, rgba(0,0,0,.04) 4px
    );
  }




  /* ── Blinking cursor ── */
  @keyframes blink { 50% { opacity: 0; } }
  .cursor-blink {
    display: inline-block; width: 8px; height: 14px;
    background: var(--amber); vertical-align: middle;
    animation: blink 1.1s step-end infinite;
  }




  /* ── Timeline ── */
  .tl-line {
    background: linear-gradient(180deg, transparent 0%, #1E2E47 15%, #1E2E47 85%, transparent 100%);
  }




  /* ── Horizontal rule ── */
  .hr-amber {
    border: none; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(240,192,96,.28), transparent);
  }




  /* ── Donate button ── */
  .donate-btn {
    background: var(--amber);
    color: #040710;
    transition: background .25s ease, transform .25s ease, box-shadow .25s ease;
  }
  .donate-btn:hover {
    background: #F5D070;
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(240,192,96,.25);
  }




  /* ── Section label ── */
  .sec-label {
    display: flex; align-items: center; gap: 10px; margin-bottom: 18px;
  }
  .sec-label::before {
    content: ''; display: block; width: 28px; height: 1px; background: var(--amber);
  }
</style>
</head>
