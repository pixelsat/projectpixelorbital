<!-- ━━━━━━━━━━━━━━━━━━━━━━━ SCRIPTS ━━━━━━━━━━━━━━━━━━━━━━━ -->
<script is:inline>
  // Countdown
  function tick() {
    const target = new Date('2026-11-01T00:00:00Z');
    const diff   = Math.max(0, target - Date.now());
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000)  / 60000);
    const s = Math.floor((diff % 60000)    / 1000);
    document.getElementById('cd-days').textContent  = String(d).padStart(3,'0');
    document.getElementById('cd-hours').textContent = String(h).padStart(2,'0');
    document.getElementById('cd-mins').textContent  = String(m).padStart(2,'0');
    document.getElementById('cd-secs').textContent  = String(s).padStart(2,'0');
  }
  tick();
  setInterval(tick, 1000);




  // Starfield
  const cv  = document.getElementById('starfield');
  const ctx = cv.getContext('2d');
  function resize() { cv.width = innerWidth; cv.height = innerHeight; }
  resize();
  addEventListener('resize', resize);




  const STARS = Array.from({length: 220}, () => ({
    x: Math.random(), y: Math.random(),
    r: Math.random() * 1.1 + 0.25,
    a: Math.random() * 0.55 + 0.15,
    ph: Math.random() * Math.PI * 2,
    sp: Math.random() * 0.006 + 0.002
  }));




  let t = 0;
  (function frame() {
    ctx.clearRect(0, 0, cv.width, cv.height);
    t += 0.012;
    for (const s of STARS) {
      const alpha = s.a * (0.55 + 0.45 * Math.sin(s.ph + t * s.sp * 60));
      ctx.beginPath();
      ctx.arc(s.x * cv.width, s.y * cv.height, s.r, 0, 6.283);
      ctx.fillStyle = `rgba(195,215,255,${alpha})`;
      ctx.fill();
    }
    requestAnimationFrame(frame);
  })();




  // Scroll reveal
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('up'); io.unobserve(e.target); }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });




  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>




