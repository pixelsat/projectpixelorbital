<section id="fund" class="py-32 relative overflow-hidden">
    <div class="fund-glow">
    </div>


    <div class="max-w-4xl mx-auto px-6 relative text-center">
        <div class="reveal">
            <div class="fund-badge reveal [transition-delay:.1s]">
                <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="font-mono text-xs text-accent tracking-widest uppercase">Support Our Mission</span>
            </div>

            <h2 class="font-display font-light text-ink mb-8 leading-tight text-[clamp(2.8rem,8vw,6rem)]">
                Help us put<br>
                <span class="accent-gradient-text">PixelSat I</span><br>
                into orbit.
            </h2>

            <p class="text-ink-muted text-lg leading-relaxed max-w-3xl mx-auto mb-12">
                Our launch is already booked. Every dollar you contribute goes directly to
                hardware: sensors, PCBs, test equipment, and the components needed to build
                a satellite that actually works. We're doing this on a $10,000 materials budget,
                roughly the price of a used car for an orbital spacecraft.
            </p>

            <!-- Budget breakdown -->
            <div class="grid md:grid-cols-3 gap-5 mb-14 text-left">
                <div class="fund-card reveal [transition-delay:.1s]">
                    <div class="font-mono text-accent text-sm mb-2">~$800</div>
                    <div class="font-display text-xl text-ink mb-2">Magnetorquers</div>
                    <p class="text-ink-muted text-xs md:text-base leading-relaxed">
                        Custom-wound copper coils, polycarbonate bobbins, H-bridge MOSFET boards,
                        and current-sensing circuitry for 3-axis attitude control.
                    </p>
                </div>
                <div class="fund-card reveal [transition-delay:.1s]">
                    <div class="font-mono text-accent text-sm mb-2">~$1,200</div>
                    <div class="font-display text-xl text-ink mb-2">UHF Transceiver</div>
                    <p class="text-ink-muted text-xs md:text-base leading-relaxed">
                        The critical radio bridge between PixelSat I at 500
                        km altitude and our SatNOGS ground stations on Earth.
                    </p>
                </div>
                <div class="fund-card reveal [transition-delay:.1s]">
                    <div class="font-mono text-accent text-sm mb-2">~$600</div>
                    <div class="font-display text-xl text-ink mb-2">Sensors & PCBs</div>
                    <p class="text-ink-muted text-xs md:text-base leading-relaxed">
                        IMU, magnetometer, power controller relay board, solar charge controller,
                        and custom interface PCBs for the ADCS and comms stacks.
                    </p>
                </div>
            </div>


            <a href="https://www.gofundme.com/f/support-project-pixel-orbital-student-team" target="_blank"
               class="donate-btn inline-flex items-center gap-2 px-4 py-3 -mt-6 text-sm rounded-xl font-medium tracking-wide sm:mt-0 sm:gap-3 sm:px-10 sm:py-5 sm:text-lg">
                Donate on GoFundMe
