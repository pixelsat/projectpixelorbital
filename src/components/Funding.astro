                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
            </a>


            <p class="mt-6 text-ink-dim text-xs font-mono">
                projectpixelorbital.com &nbsp;·&nbsp; Stanford Online High School &nbsp;·&nbsp; Est. Feb 2025
            </p>
