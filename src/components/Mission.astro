<section id="mission" class="py-32 relative">
  <div class="w-full max-w-none mx-auto px-8">




    <div class="reveal mb-20">
      <div class="sec-label">
        <span class="font-mono text-xs text-amber-glow tracking-widest uppercase">Mission Overview</span>
      </div>
      <h2 class="font-display font-light text-frost-100" style="font-size:clamp(2.5rem,6vw,4.5rem)">
        Why we're going to orbit
      </h2>
    </div>




    <div class="grid lg:grid-cols-2 gap-14 items-start">




      <!-- Objectives -->
      <div class="space-y-5 max-w-md mx-auto lg:max-w-none lg:mx-0">
        <div class="glass rounded-2xl p-7 card-hover reveal">
          <div class="flex flex-col items-center text-center gap-4 lg:flex-row lg:items-start lg:text-left lg:gap-5">
            <span class="font-mono text-5xl font-bold text-amber-glow/20 leading-none shrink-0">01</span>
            <div>
              <h3 class="font-display text-2xl font-medium text-frost-100 mb-2">Validate Additive Manufacturing</h3>
              <p class="text-frost-500 text-sm leading-relaxed">
                Demonstrate that a 3D-printed carbon-fiber-filled PPO frame survives launch loads,
                thermal cycling from -40°C to +80°C, and orbital radiation, at only a fraction of
                the cost of machined titanium.
              </p>
            </div>
          </div>
        </div>




        <div class="glass rounded-2xl p-7 card-hover reveal" style="transition-delay:.08s">
          <div class="flex flex-col items-center text-center gap-4 lg:flex-row lg:items-start lg:text-left lg:gap-5">
            <span class="font-mono text-5xl font-bold text-amber-glow/20 leading-none shrink-0">02</span>
            <div>
              <h3 class="font-display text-2xl font-medium text-frost-100 mb-2">Proof-of-Mission Imagery from Orbit</h3>
              <p class="text-frost-500 text-sm leading-relaxed">
                Capture and downlink a clear photo of the school's Pixel mascot figure against Earth.
                Requires a complete pipeline: 3-axis ADCS pointing, 720p camera payload,
                JPEG/AVIF compression, chunked streaming, and successful RF downlink.
              </p>
            </div>
          </div>
        </div>




        <div class="glass rounded-2xl p-7 card-hover reveal" style="transition-delay:.16s">
          <div class="flex flex-col items-center text-center gap-4 lg:flex-row lg:items-start lg:text-left lg:gap-5">
            <span class="font-mono text-5xl font-bold text-amber-glow/20 leading-none shrink-0">03</span>
            <div>
              <h3 class="font-display text-2xl font-medium text-frost-100 mb-2">Microgravity Drug Research</h3>
              <p class="text-frost-500 text-sm leading-relaxed">
                Operate a student-designed protein crystallization experiment in microgravity
                and relay structured data to ground, contributing to research on
                pharmaceutical manufacturing in space.
              </p>
            </div>
          </div>
        </div>




        <div class="glass rounded-2xl p-7 card-hover reveal" style="transition-delay:.24s">
          <div class="flex flex-col items-center text-center gap-4 lg:flex-row lg:items-start lg:text-left lg:gap-5">
            <span class="font-mono text-5xl font-bold text-amber-glow/20 leading-none shrink-0">04</span>
            <div>
              <h3 class="font-display text-2xl font-medium text-frost-100 mb-2">Prove the High-School Model</h3>
              <p class="text-frost-500 text-sm leading-relaxed">
                Show that a team of high schoolers with no adult engineering oversight
                and a $10,000 hardware budget can conceive, build, launch, and operate
                a functional orbital spacecraft.
              </p>
            </div>
          </div>
        </div>
      </div>




      <!-- Telemetry panel -->
      <div class="reveal" style="transition-delay:.2s">
        <div class="glass rounded-2xl overflow-hidden relative scanlines">
        
          <!-- Header bar -->
          <div class="flex items-center justify-between px-6 py-3 border-b"
               style="background:rgba(22,35,60,.7);border-color:var(--border)">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
              <span class="font-mono text-xs text-frost-500 tracking-widest">PIXELSAT-I · MISSION DATA</span>
            </div>
            <span class="font-mono text-xs text-frost-700">DESIGN PHASE</span>
          </div>




          <!-- Satellite render -->
          <div class="flex justify-center py-10 border-b" style="background:rgba(7,12,26,.5);border-color:var(--border)">
            <img src="https://static.wixstatic.com/media/a77f8c_f2f26de146da4524891674b0307de824~mv2.png/v1/fill/w_360,h_540,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/a77f8c_f2f26de146da4524891674b0307de824~mv2.png"
                 alt="PixelSat I 3U CubeSat render"
                 class="h-52 w-auto object-contain opacity-90 drop-shadow-2xl">
          </div>




          <!-- Specs table -->
          <div class="px-6 py-4 space-y-0 font-mono text-[11px] sm:text-xs">
            <div class="flex justify-between py-2.5 border-b" style="border-color:rgba(30,46,71,.55)">
              <span class="text-frost-500">Form Factor</span>
              <span class="text-amber-glow block text-right ml-auto">
                3U CubeSat · 100×100×300 mm
              </span>
            </div>
            <div class="flex justify-between py-2.5 border-b" style="border-color:rgba(30,46,71,.55)">
              <span class="text-frost-500">Target Mass</span>
              <span class="text-frost-100">&lt; 6 kg</span>
            </div>
            <div class="flex justify-between py-2.5 border-b" style="border-color:rgba(30,46,71,.55)">
              <span class="text-frost-500">Orbit</span>
              <span class="text-frost-100">Sun-Synchronous LEO</span>
            </div>
            <div class="flex justify-between py-2.5 border-b" style="border-color:rgba(30,46,71,.55)">
              <span class="text-frost-500">Launch Date</span>
              <span class="text-amber-glow">NET November 2026</span>
            </div>
            <div class="flex justify-between py-2.5 border-b" style="border-color:rgba(30,46,71,.55)">
              <span class="text-frost-500">Structure</span>
              <span class="text-frost-100">3D-printed PPS-CF</span>
            </div>
            <div class="flex justify-between py-2.5 border-b" style="border-color:rgba(30,46,71,.55)">
              <span class="text-frost-500">Comms</span>
              <span class="text-frost-100">UHF · 435–438 MHz GMSK</span>
            </div>
            <div class="flex justify-between py-2.5">
              <span class="text-frost-500">Hardware Budget</span>
              <span class="text-amber-glow">~$10,000</span>
            </div>
          </div>
        </div>


        
        <!-- Stats -->
<div class="grid grid-cols-3 gap-4 mt-5">
  <div class="glass rounded-xl p-4 flex flex-col items-center justify-center text-center card-hover">
    <div class="font-mono text-2xl text-amber-glow font-bold">18+</div>
    <div class="text-center text-[9px] sm:text-xs text-frost-700 tracking-wide mt-1 leading-tight block">
      Team Members
    </div>
  </div>

  <div class="glass rounded-xl p-4 flex flex-col items-center justify-center text-center card-hover">
    <div class="font-mono text-2xl text-amber-glow font-bold">5</div>
    <div class="text-center text-[9px] sm:text-xs text-frost-700 tracking-wide mt-1 leading-tight block">
      Subsystems
    </div>
  </div>

  <div class="glass rounded-xl p-4 flex flex-col items-center justify-center text-center card-hover">
    <div class="font-mono text-2xl text-amber-glow font-bold">0</div>
    <div class="text-center text-[9px] sm:text-xs text-frost-700 tracking-wide mt-1 leading-tight block">
      Adult Supervisors
    </div>
  </div>
</div>


    </div>
  </div>
</section>
